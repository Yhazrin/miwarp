# Enforce LF line endings for all text files.
# Prevents CRLF/LF mixing that breaks hashes, diffs, and some tools.
* text=auto eol=lf

# Explicit binary files — do not normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.wasm binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
