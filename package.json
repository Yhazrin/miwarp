{
  "name": "miwarp",
  "version": "1.1.3",
  "description": "Local-first desktop app for AI-assisted vibe coding",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Yhazrin/miwarp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yhazrin/miwarp.git"
  },
  "bugs": {
    "url": "https://github.com/Yhazrin/miwarp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:desktop": "bash scripts/dev-desktop.sh",
    "prebuild": "node scripts/sync-version.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:runtime-e2e": "node scripts/runtime-real-e2e.mjs",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "rust:check": "npm run rust:fmt && npm run rust:clippy",
    "i18n:check": "node scripts/i18n-check.mjs",
    "doc:check": "node scripts/doc-check.mjs",
    "check:root": "node scripts/check-root-pollution.mjs",
    "arch:direction": "node scripts/architecture/direction-check.mjs",
    "arch:layers": "node scripts/architecture/layer-import-check.mjs",
    "arch:cycle": "node scripts/architecture/cycle-check.mjs",
    "arch:budget": "node scripts/architecture/file-budget.mjs",
    "arch:tauri-contract": "node scripts/architecture/tauri-contract.mjs",
    "arch:ios-ws-contract": "node scripts/architecture/ios-ws-contract.mjs",
    "arch:cross-platform-bus": "node scripts/architecture/cross-platform-bus-contract.mjs",
    "arch:mobile-bus-contract": "node scripts/architecture/mobile-bus-contract.mjs",
    "arch:runtime-contract": "vitest run scripts/architecture/__tests__/runtime-contract.test.ts",
    "arch:budget:diff": "node scripts/architecture/file-budget-diff.mjs",
    "arch:perf-budget": "node scripts/architecture/perf-budget.mjs",
    "arch:perf-budget:runtime": "node scripts/architecture/perf-budget.mjs --runtime",
    "arch:check": "npm run arch:direction && npm run arch:layers && npm run arch:cycle && npm run arch:budget && npm run arch:perf-budget && npm run arch:tauri-contract && npm run arch:ios-ws-contract && npm run arch:cross-platform-bus && npm run arch:mobile-bus-contract && npm run arch:runtime-contract",
    "arch:check:strict": "npm run arch:check && npm run arch:budget:diff",
    "test:contract": "vitest run scripts/architecture/__tests__/runtime-contract.test.ts src/lib/bus/__tests__/bus-contract.test.ts scripts/architecture/__tests__/contract-lib.test.ts",
    "fix": "npm run lint:fix && npm run format && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "verify": "npm run check:root && npm run lint && npm run format:check && npm run check && npm run i18n:check && npm run test && npm run build && npm run rust:check",
    "verify:rc": "bash scripts/verify-rc.sh",
    "verify:rc:skip-dev": "bash scripts/verify-rc.sh --skip-dev",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/check-versions.mjs",
    "release:notes": "node scripts/generate-release-notes.mjs",
    "release": "node scripts/release.mjs",
    "perf:compare": "node scripts/perf-compare.mjs",
    "prebuild:dmg": "node scripts/clean-dmg.mjs",
    "build:dmg": "TAURI_TARGET=aarch64-apple-darwin npm run prebuild:dmg && npm run tauri build -- --target aarch64-apple-darwin",
    "build:dmg:universal": "TAURI_TARGET=universal-apple-darwin npm run prebuild:dmg && npm run tauri build -- --target universal-apple-darwin",
    "build:win": "npm run tauri build -- --target x86_64-pc-windows-msvc",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/cli": "^2.5.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.7.0",
    "@types/qrcode": "^1.5.6",
    "@types/turndown": "^5.0.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.3.0",
    "jsdom": "^29.1.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "sharp": "^0.34.5",
    "svelte": "^5.53.3",
    "svelte-check": "^4.3.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.55.0",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bits-ui": "^2.18.1",
    "codemirror": "^6.0.1",
    "diff": "^8.0.3",
    "dompurify": "^3.2.4",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.0",
    "mammoth": "^1.11.0",
    "marked": "^15.0.0",
    "mermaid": "^11.15.0",
    "picomatch": "^4.0.4",
    "qrcode": "^1.5.4",
    "turndown": "^7.2.2",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3"
  },
  "browserslist": [
    "safari >= 16.1",
    "chrome >= 105",
    "edge >= 105"
  ]
}
